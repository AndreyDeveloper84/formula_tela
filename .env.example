DJANGO_SECRET_KEY=change-me123
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000

# YClients API credentials
YCLIENTS_PARTNER_TOKEN=
YCLIENTS_USER_TOKEN=
YCLIENTS_COMPANY_ID=

# YooKassa (онлайн-оплата услуг)
# Получаются в личном кабинете YooKassa: https://yookassa.ru/my/merchant/integration/api
# Включение кнопки «Оплатить онлайн» на сайте — через Django Admin:
# /admin/services_app/sitesettings/ → Онлайн-оплата через YooKassa.
# ВАЖНО: test_* ключи для staging/dev, live_* — только на проде.
YOOKASSA_SHOP_ID=<shop_id_из_личного_кабинета>
YOOKASSA_SECRET_KEY=<test_или_live_secret_key>
YOOKASSA_RETURN_URL=https://formulatela58.ru/payments/success/?order={order_number}

# --- БАЗА ДАННЫХ ---
# Вариант 1: SQLite (быстрый старт, без Docker)
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=data/db.sqlite3

# Вариант 2: PostgreSQL через Docker (рекомендуется, = прод)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=mysite_db
DB_USER=mysite_user
DB_PASSWORD=mysite_pass
DB_HOST=127.0.0.1
DB_PORT=5432

# --- САЙТ ---
SITE_BASE_URL=https://formulatela58.ru
